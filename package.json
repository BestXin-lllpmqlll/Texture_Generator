{
  "name": "texture-generator",
  "version": "0.1.0",
  "private": true,
  "description": "A desktop tool that generates random texture/array images from a base image and element set.",
  "author": "Texture Generator",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
